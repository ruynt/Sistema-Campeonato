generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoParticipante {
  DUPLA
  TIME
}

enum CategoriaCampeonato {
  MASCULINO
  FEMININO
  MISTA
}

enum StatusInscricao {
  PENDENTE
  APROVADA
  RECUSADA
}

enum StatusJogo {
  PENDENTE
  FINALIZADO
}

enum FormatoCampeonato {
  MATA_MATA
  DUPLA_ELIMINACAO
  TODOS_CONTRA_TODOS
  GRUPOS_3X4_REPESCAGEM
}

enum PapelUsuario {
  ADMIN
  PARTICIPANTE
}

enum SexoUsuario {
  MASCULINO
  FEMININO
  OUTRO
  PREFIRO_NAO_INFORMAR
}

model Usuario {
  id             Int          @id @default(autoincrement())
  nome           String
  email          String       @unique
  contato        String?
  dataNascimento DateTime?
  sexo           SexoUsuario?
  fotoPerfil     String?
  senhaHash      String
  papel          PapelUsuario
  criadoEm       DateTime     @default(now())

  inscricoes     Participante[]
}

model Campeonato {
  id                Int                  @id @default(autoincrement())
  nome              String
  data              DateTime?
  local             String?
  tipoParticipante  TipoParticipante
  categoria         CategoriaCampeonato
  formato           FormatoCampeonato    @default(MATA_MATA)
  quantidadeMaxima  Int?
  inscricoesAbertas Boolean              @default(true)
  criadoEm          DateTime             @default(now())

  participantes     Participante[]
  jogos             Jogo[]
}

model Participante {
  id              Int              @id @default(autoincrement())
  nomeEquipe      String
  responsavel     String
  contato         String?
  statusInscricao StatusInscricao  @default(PENDENTE)
  criadoEm        DateTime         @default(now())

  campeonatoId    Int
  campeonato      Campeonato       @relation(fields: [campeonatoId], references: [id], onDelete: Cascade)

  usuarioId       Int?
  usuario         Usuario?         @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  jogadores       Jogador[]

  jogosComoA      Jogo[]           @relation("JogoEquipeA")
  jogosComoB      Jogo[]           @relation("JogoEquipeB")
  jogosVencidos   Jogo[]           @relation("JogoVencedor")

  @@unique([campeonatoId, nomeEquipe])
}

model Jogador {
  id             Int          @id @default(autoincrement())
  nome           String
  genero         String

  participanteId Int
  participante   Participante @relation(fields: [participanteId], references: [id], onDelete: Cascade)
}

model Jogo {
  id           Int           @id @default(autoincrement())
  fase         String
  grupo        String?
  rodada       Int?
  ordem        Int?
  status       StatusJogo    @default(PENDENTE)
  criadoEm     DateTime      @default(now())

  campeonatoId Int
  campeonato   Campeonato    @relation(fields: [campeonatoId], references: [id], onDelete: Cascade)

  equipeAId    Int?
  equipeA      Participante? @relation("JogoEquipeA", fields: [equipeAId], references: [id])

  equipeBId    Int?
  equipeB      Participante? @relation("JogoEquipeB", fields: [equipeBId], references: [id])

  vencedorId   Int?
  vencedor     Participante? @relation("JogoVencedor", fields: [vencedorId], references: [id])

  sets         SetJogo[]
}

model SetJogo {
  id        Int  @id @default(autoincrement())
  numeroSet Int
  pontosA   Int
  pontosB   Int

  jogoId    Int
  jogo      Jogo @relation(fields: [jogoId], references: [id], onDelete: Cascade)
}